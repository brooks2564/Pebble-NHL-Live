{
  "name": "nhl-live-scores",
  "author": "brooks2564",
  "version": "1.0.0",
  "keywords": ["pebble-app"],
  "private": true,
  "dependencies": {},
  "pebble": {
    "displayName": "NHL Live",
    "shortName": "NHL Live",
    "longName": "NHL Live Scores",
    "uuid": "b3c4d5e6-f7a8-4901-b234-c5d6e7f8a901",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "targetPlatforms": [
      "aplite",
      "basalt",
      "chalk",
      "diorite",
      "emery",
      "flint",
      "gabbro"
    ],
    "watchapp": {
      "watchface": true
    },
    "capabilities": ["configurable"],
    "messageKeys": {
      "AWAY_ABBR":    1,
      "HOME_ABBR":    2,
      "AWAY_SCORE":   3,
      "HOME_SCORE":   4,
      "PERIOD":       5,
      "PERIOD_TIME":  6,
      "STATUS":       10,
      "TEAM_IDX":     11,
      "START_TIME":   12,
      "AWAY_WINS":    13,
      "AWAY_LOSSES":  14,
      "HOME_WINS":    15,
      "HOME_LOSSES":  16,
      "VIBRATE":      17,
      "AWAY_SHOTS":   18,
      "HOME_SHOTS":   19,
      "LAST_GOAL":    20,
      "AWAY_SKATERS": 21,
      "HOME_SKATERS": 22,
      "PENALTY_SECS": 23,
      "NEXT_GAME":    24,
      "BATTERY_BAR":  25,
      "TICKER":       26,
      "TZ_OFFSET":    31,
      "TICKER_SPEED": 32
    },
    "resources": {
      "media": [
        {
          "type": "bitmap",
          "name": "IMAGE_STICK_PUCK",
          "file": "images/stick_puck.png"
        },
        {
          "type": "bitmap",
          "name": "IMAGE_ICE_CLEANER",
          "file": "images/ice_cleaner.png"
        }
      ]
    }
  }
}
